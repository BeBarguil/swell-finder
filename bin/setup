#!/bin/bash

# Surf Spot Finder - Setup Automático
# Este script configura o projeto automaticamente

set -e  # Para em caso de erro

echo "🏄‍♂️ Bem-vindo ao Surf Spot Finder Setup!"
echo "=========================================="
echo ""

# Cores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Função para mensagens de sucesso
success() {
    echo -e "${GREEN}✓ $1${NC}"
}

# Função para mensagens de erro
error() {
    echo -e "${RED}✗ $1${NC}"
}

# Função para mensagens de info
info() {
    echo -e "${YELLOW}→ $1${NC}"
}

# 1. Verificar Ruby
info "Verificando instalação do Ruby..."
if command -v ruby &> /dev/null; then
    RUBY_VERSION=$(ruby -v)
    success "Ruby instalado: $RUBY_VERSION"
else
    error "Ruby não encontrado. Por favor, instale Ruby 3.2.0 ou superior."
    exit 1
fi

# 2. Verificar Rails
info "Verificando instalação do Rails..."
if command -v rails &> /dev/null; then
    RAILS_VERSION=$(rails -v)
    success "Rails instalado: $RAILS_VERSION"
else
    info "Rails não encontrado. Instalando..."
    gem install rails
    success "Rails instalado com sucesso!"
fi

# 3. Verificar PostgreSQL
info "Verificando instalação do PostgreSQL..."
if command -v psql &> /dev/null; then
    PSQL_VERSION=$(psql --version)
    success "PostgreSQL instalado: $PSQL_VERSION"
else
    error "PostgreSQL não encontrado."
    info "Para instalar:"
    echo "  - Ubuntu/Debian: sudo apt-get install postgresql postgresql-contrib"
    echo "  - macOS: brew install postgresql"
    exit 1
fi

# 4. Instalar dependências
info "Instalando gems..."
if bundle install; then
    success "Gems instaladas com sucesso!"
else
    error "Erro ao instalar gems. Verifique o Gemfile."
    exit 1
fi

# 5. Verificar se database.yml existe
if [ ! -f "config/database.yml" ]; then
    error "config/database.yml não encontrado!"
    info "Criando arquivo de configuração padrão..."
    
    cat > config/database.yml << EOL
default: &default
  adapter: postgresql
  encoding: unicode
  pool: <%= ENV.fetch("RAILS_MAX_THREADS") { 5 } %>

development:
  <<: *default
  database: surf_spot_finder_development

test:
  <<: *default
  database: surf_spot_finder_test

production:
  <<: *default
  database: surf_spot_finder_production
  username: surf_spot_finder
  password: <%= ENV["SURF_SPOT_FINDER_DATABASE_PASSWORD"] %>
EOL
    success "database.yml criado!"
fi

# 6. Criar banco de dados
info "Criando banco de dados..."
if rails db:create; then
    success "Banco de dados criado!"
else
    error "Erro ao criar banco. Verifique configurações do PostgreSQL."
    exit 1
fi

# 7. Rodar migrations
info "Executando migrations..."
if rails db:migrate; then
    success "Migrations executadas com sucesso!"
else
    error "Erro ao executar migrations."
    exit 1
fi

# 8. Popular banco com seeds
info "Populando banco de dados com dados de exemplo..."
if rails db:seed; then
    success "Banco populado com sucesso!"
else
    error "Erro ao popular banco."
    exit 1
fi

# 9. Verificar testes
info "Verificando se testes passam..."
if bundle exec rspec; then
    success "Todos os testes passaram!"
else
    error "Alguns testes falharam. Verifique os erros acima."
fi

echo ""
echo "=========================================="
echo -e "${GREEN}✨ Setup concluído com sucesso!${NC}"
echo "=========================================="
echo ""
echo "Para iniciar o servidor:"
echo "  $ rails server"
echo ""
echo "Depois acesse: http://localhost:3000"
echo ""
echo "Comandos úteis:"
echo "  $ rails console          # Console interativo"
echo "  $ rails routes           # Ver todas as rotas"
echo "  $ bundle exec rspec      # Rodar testes"
echo "  $ rails db:reset         # Resetar banco de dados"
echo ""
echo "🏄‍♂️ Boas ondas e bom código!"
