<div class="container mx-auto px-4 py-8">
  <div class="text-center mb-12">
    <h1 class="text-5xl font-bold text-gray-900 mb-4">
      Encontre as Melhores Ondas
    </h1>
    <p class="text-xl text-gray-600 mb-8">
      Descubra praias próximas com condições perfeitas para surf
    </p>
    
    <div class="flex flex-col items-center gap-4 mb-6">
      <button 
        id="use-location-btn"
        class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg shadow-lg transition-all duration-200 transform hover:scale-105 flex items-center gap-2"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span id="btn-text">Usar Minha Localização</span>
      </button>
      
      <% if @user_location %>
        <div class="flex flex-col sm:flex-row items-center gap-3 bg-white rounded-lg shadow-md p-4 max-w-2xl w-full">
          <div class="flex items-center gap-2 text-green-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="font-medium">Localização obtida!</span>
          </div>
          
          <div class="flex items-center gap-2">
            <label for="distance-filter" class="text-gray-700 font-medium whitespace-nowrap">
              Raio de busca:
            </label>
            <select 
              id="distance-filter" 
              class="border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              onchange="updateDistance(this.value)"
            >
              <option value="">Todas as praias</option>
              <option value="50" <%= 'selected' if @max_distance == 50 %>>Até 50 km</option>
              <option value="100" <%= 'selected' if @max_distance == 100 %>>Até 100 km</option>
              <option value="200" <%= 'selected' if @max_distance == 200 %>>Até 200 km</option>
              <option value="500" <%= 'selected' if @max_distance == 500 %>>Até 500 km</option>
            </select>
          </div>
        </div>
        
        <div class="text-gray-600">
          <span class="font-semibold text-blue-600"><%= @total_found %></span> 
          <%= @total_found == 1 ? 'praia encontrada' : 'praias encontradas' %>
          <% if @max_distance %>
            em um raio de <%= @max_distance %> km
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @beaches.empty? && @user_location %>
    <div class="max-w-md mx-auto bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
      <svg class="w-12 h-12 text-yellow-500 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <h3 class="text-lg font-semibold text-yellow-800 mb-2">Nenhuma praia encontrada</h3>
      <p class="text-yellow-700 mb-4">Não há praias cadastradas dentro do raio selecionado.</p>
      <button 
        onclick="updateDistance('')"
        class="bg-yellow-600 hover:bg-yellow-700 text-white font-medium py-2 px-4 rounded-lg transition-colors"
      >
        Mostrar todas as praias
      </button>
    </div>
  <% else %>
    <div id="beaches-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @beaches.each_with_index do |beach, index| %>
        <% distance_info = @beaches_with_distance.find { |b| b[:beach].id == beach.id } %>
        <%= render partial: 'beach_card', locals: { 
          beach: beach, 
          distance: distance_info ? distance_info[:distance] : nil 
        } %>
      <% end %>
    </div>
  <% end %>
</div>

<script>
function updateDistance(distance) {
  const urlParams = new URLSearchParams(window.location.search);
  if (distance) {
    urlParams.set('distance', distance);
  } else {
    urlParams.delete('distance');
  }
  window.location.search = urlParams.toString();
}

document.getElementById('use-location-btn').addEventListener('click', function() {
  const btn = this;
  const btnText = document.getElementById('btn-text');
  
  btn.disabled = true;
  btn.classList.add('opacity-75');
  btnText.textContent = 'Obtendo localização...';
  
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      function(position) {
        const lat = position.coords.latitude;
        const lng = position.coords.longitude;
        btnText.textContent = 'Carregando praias...';
        window.location.href = `/?lat=${lat}&lng=${lng}`;
      }, 
      function(error) {
        btn.disabled = false;
        btn.classList.remove('opacity-75');
        btnText.textContent = 'Usar Minha Localização';
        
        let message = 'Não foi possível obter sua localização.';
        if (error.code === error.PERMISSION_DENIED) {
          message = 'Permissão negada. Ative a localização nas configurações do navegador.';
        }
        alert(message);
      }
    );
  } else {
    btn.disabled = false;
    btn.classList.remove('opacity-75');
    btnText.textContent = 'Usar Minha Localização';
    alert('Geolocalização não é suportada pelo seu navegador.');
  }
});
</script>
