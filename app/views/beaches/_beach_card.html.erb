<div class="bg-white rounded-lg shadow-md hover:shadow-xl transition-shadow duration-300 overflow-hidden">
  <div class="p-6">
    <h3 class="text-2xl font-bold text-gray-900 mb-2"><%= beach.name %></h3>
    <p class="text-gray-600 mb-4"><%= beach.city %>, <%= beach.state %></p>
    
    <% difficulty_colors = {
      'beginner' => 'bg-green-100 text-green-800',
      'intermediate' => 'bg-yellow-100 text-yellow-800',
      'advanced' => 'bg-red-100 text-red-800'
    } %>
    
    <% difficulty_labels = {
      'beginner' => 'Iniciante',
      'intermediate' => 'Intermediário',
      'advanced' => 'Avançado/Profissional'
    } %>
    
    <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold mb-4 <%= difficulty_colors[beach.difficulty_level] %>">
      <%= difficulty_labels[beach.difficulty_level] %>
    </span>

    <% conditions = beach.current_conditions %>
    <% if conditions %>
      <div class="mt-4">
        <h4 class="font-semibold text-gray-700 mb-2">Condições Atuais</h4>
        <div class="grid grid-cols-2 gap-3 mb-4">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            <div>
              <p class="text-xs text-gray-500">Ondas</p>
              <p class="font-semibold text-gray-900"><%= conditions.wave_height %>m</p>
            </div>
          </div>
          
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
            <div>
              <p class="text-xs text-gray-500">Vento</p>
              <p class="font-semibold text-gray-900"><%= conditions.wind_speed %> km/h <%= conditions.wind_direction_label %></p>
            </div>
          </div>
        </div>

        <% quality_colors = {
          'excellent' => 'bg-green-500',
          'good' => 'bg-yellow-500',
          'fair' => 'bg-orange-500',
          'poor' => 'bg-gray-400',
          'flat' => 'bg-gray-400'
        } %>
        
        <% quality_labels = {
          'excellent' => 'Excelente',
          'good' => 'Bom',
          'fair' => 'Pequeno',
          'poor' => 'Pequeno',
          'flat' => 'Flat'
        } %>
        
        <div class="mb-3">
          <div class="text-xs text-gray-500 mb-1">Qualidade</div>
          <div class="<%= quality_colors[conditions.swell_quality] %> text-white px-3 py-1 rounded text-center font-semibold">
            <%= quality_labels[conditions.swell_quality] %>
          </div>
        </div>

        <% if conditions.good_conditions? %>
          <div class="bg-green-50 border border-green-200 rounded-lg p-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm text-green-800 font-medium">Boas condições para surfar!</span>
          </div>
        <% else %>
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
            <span class="text-sm text-yellow-800 font-medium">Condições fracas</span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= link_to beach_path(beach), class: "mt-4 block w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg text-center transition-colors duration-200" do %>
      Ver Detalhes
    <% end %>
  </div>
</div>
