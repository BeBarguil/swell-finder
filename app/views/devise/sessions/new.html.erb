<div class="container mx-auto px-4 py-12">
  <div class="max-w-md mx-auto bg-white rounded-lg shadow-lg p-8">
    <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">Entrar</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, "E-mail", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "Senha", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-4 flex items-center">
          <%= f.check_box :remember_me, class: "w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
          <%= f.label :remember_me, "Lembrar de mim", class: "ml-2 text-gray-700" %>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.submit "Entrar", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="text-center">
      <div class="text-gray-600 mb-2">
        Não tem uma conta?
        <%= link_to "Criar conta", new_registration_path(resource_name), class: "text-blue-600 hover:text-blue-700 font-medium" %>
      </div>
      <% if devise_mapping.recoverable? %>
        <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-sm text-gray-500 hover:text-gray-700" %>
      <% end %>
    </div>
  </div>
</div>
