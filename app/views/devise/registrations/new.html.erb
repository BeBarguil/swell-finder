<div class="container mx-auto px-4 py-12">
  <div class="max-w-md mx-auto bg-white rounded-lg shadow-lg p-8">
    <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">Criar Conta</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :name, "Nome", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.text_field :name, autofocus: true, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :email, "E-mail", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.email_field :email, autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "Senha", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <% if @minimum_password_length %>
          <p class="text-sm text-gray-500 mt-1">Mínimo <%= @minimum_password_length %> caracteres</p>
        <% end %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, "Confirmar Senha", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.submit "Criar Conta", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="text-center text-gray-600">
      Já tem uma conta?
      <%= link_to "Entrar", new_session_path(resource_name), class: "text-blue-600 hover:text-blue-700 font-medium" %>
    </div>
  </div>
</div>
