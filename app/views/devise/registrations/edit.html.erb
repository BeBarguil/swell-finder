<div class="container mx-auto px-4 py-12">
  <div class="max-w-md mx-auto bg-white rounded-lg shadow-lg p-8">
    <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">Editar Perfil</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :name, "Nome", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.text_field :name, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :email, "E-mail", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.email_field :email, autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "Nova Senha", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "Deixe em branco para não alterar", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="text-sm text-gray-500 mt-1">Mínimo 6 caracteres</p>
      </div>

      <div class="mb-4">
        <%= f.label :password_confirmation, "Confirmar Nova Senha", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-6">
        <%= f.label :current_password, "Senha Atual", class: "block text-gray-700 font-medium mb-2" %>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="text-sm text-gray-500 mt-1">Necessária para confirmar alterações</p>
      </div>

      <div class="mb-4">
        <%= f.submit "Atualizar", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="pt-4 border-t border-gray-200">
      <%= button_to "Cancelar minha conta", registration_path(resource_name), data: { confirm: "Tem certeza?", turbo_confirm: "Tem certeza?" }, method: :delete, class: "w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2 rounded-lg transition-colors" %>
    </div>

    <div class="mt-4 text-center">
      <%= link_to "Voltar", :back, class: "text-blue-600 hover:text-blue-700" %>
    </div>
  </div>
</div>
