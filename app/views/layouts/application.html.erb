<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>Surf Spot Finder - Encontre as Melhores Ondas</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Encontre as melhores praias para surfar perto de você.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gradient-to-br from-blue-50 to-cyan-50 min-h-screen">
    <nav class="bg-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <a href="/" class="flex items-center space-x-2">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"></path>
              </svg>
              <span class="text-xl font-bold text-gray-900">Surf Spot Finder</span>
            </a>
          </div>
          <div class="flex items-center space-x-4">
            <a href="/" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium transition-colors">
              Praias
            </a>
            <a href="https://github.com/BeBarguil/swell-finder" target="_blank" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium transition-colors">
              GitHub
            </a>
          </div>
        </div>
      </div>
    </nav>
    <main>
      <%= yield %>
    </main>
    <footer class="bg-white mt-12 border-t border-gray-200">
      <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
        <p class="text-center text-gray-500 text-sm">
          &copy; <%= Time.current.year %> Surf Spot Finder. Feito com ❤️ para surfistas.
        </p>
      </div>
    </footer>
  </body>
</html>
